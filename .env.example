# העתק ל-.env והשלם ערכים (הקובץ .env לא נכנס ל-git)
# Alpha Vantage — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Alpaca Paper Trading — https://alpaca.markets (Paper Only account, free)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Grok (xAI) — https://console.x.ai/ — for news sentiment analysis
GROK_API_KEY=

# Telegram Alerts (optional) — create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live trading safety flag — set to "yes" to allow live execution
I_ACCEPT_LIVE_RISK=
I_ACCEPT_PLAN_B_LIVE_RISK=

# Plan B profile name (e.g. plan_b_us)
PLAN_B_PROFILE=

# E2E test flag
AIBROKER_E2E=
